{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "photoURL": { "type": "string", "description": "The user's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the user was created" }
      },
      "required": ["uid", "email"]
    },
    "ChatHistory": {
      "title": "ChatHistory",
      "description": "User's chat history with the AI doctor",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user ID" },
        "role": { "type": "string", "enum": ["user", "model"], "description": "The role of the message sender" },
        "text": { "type": "string", "description": "The message text" },
        "timestamp": { "type": "string", "format": "date-time", "description": "The time the message was sent" }
      },
      "required": ["userId", "role", "text", "timestamp"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "User's doctor appointments",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user ID" },
        "doctorName": { "type": "string", "description": "The doctor's name" },
        "specialty": { "type": "string", "description": "The doctor's specialty" },
        "date": { "type": "string", "description": "The appointment date" },
        "time": { "type": "string", "description": "The appointment time" },
        "reason": { "type": "string", "description": "The reason for the visit" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "The appointment status" },
        "createdAt": { "type": "number", "description": "The time the appointment was booked" }
      },
      "required": ["userId", "doctorName", "date", "time", "status", "createdAt"]
    },
    "VitalSigns": {
      "title": "VitalSigns",
      "description": "User's health vitals tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user ID" },
        "timestamp": { "type": "number", "description": "The time the vitals were recorded" },
        "weight": { "type": "number", "description": "The user's weight in kg" },
        "bloodPressureSystolic": { "type": "number", "description": "Systolic blood pressure" },
        "bloodPressureDiastolic": { "type": "number", "description": "Diastolic blood pressure" },
        "heartRate": { "type": "number", "description": "Heart rate in bpm" },
        "temperature": { "type": "number", "description": "Body temperature in Celsius" }
      },
      "required": ["userId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatHistory",
      "description": "User's chat history"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Doctor appointments"
    },
    "/vitals/{vitalId}": {
      "schema": "VitalSigns",
      "description": "Health vitals tracking"
    }
  }
}
