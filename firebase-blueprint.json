{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "photoURL": { "type": "string", "description": "The user's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the user was created" },
        "consultationId": { "type": "string", "description": "Permanent 6-digit numeric consultation ID" }
      },
      "required": ["uid", "email"]
    },
    "ChatHistory": {
      "title": "ChatHistory",
      "description": "User's chat history with the AI doctor",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user ID" },
        "role": { "type": "string", "enum": ["user", "model"], "description": "The role of the message sender" },
        "text": { "type": "string", "description": "The message text" },
        "timestamp": { "type": "string", "format": "date-time", "description": "The time the message was sent" }
      },
      "required": ["userId", "role", "text", "timestamp"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "User's medication reminders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "medicines": { "type": "array", "items": { "type": "object" } },
        "time": { "type": "string" },
        "dates": { "type": "array", "items": { "type": "string" } },
        "days": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "takenDates": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "medicines", "time", "days", "active"]
    },
    "SymptomHistory": {
      "title": "SymptomHistory",
      "description": "User's symptom analysis history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" },
        "symptoms": { "type": "string" },
        "analysis": { "type": "object" }
      },
      "required": ["id", "timestamp", "symptoms", "analysis"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "User's favorite medicines",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "info": { "type": "object" }
      },
      "required": ["id", "name", "info"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique doctor ID" },
        "name": { "type": "string", "description": "Doctor's full name" },
        "speciality": { "type": "string", "description": "Doctor's speciality" },
        "sittingTime": { "type": "string", "description": "Availability time" },
        "daysAvailable": { "type": "array", "items": { "type": "string" }, "description": "Days available" },
        "hospitalName": { "type": "string", "description": "Hospital or Clinic name" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "email": { "type": "string", "format": "email", "description": "Doctor's email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the doctor profile was created" }
      },
      "required": ["uid", "name", "speciality", "sittingTime", "daysAvailable", "hospitalName", "phone"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "User's medical appointments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "doctorName": { "type": "string" },
        "specialty": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "doctorName", "specialty", "date", "time", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": "ChatHistory",
      "description": "User's chat history"
    },
    "/users/{userId}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "User's medication reminders"
    },
    "/users/{userId}/symptoms/{symptomId}": {
      "schema": "SymptomHistory",
      "description": "User's symptom history"
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User's favorite medicines"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "User's medical appointments"
    }
  }
}
